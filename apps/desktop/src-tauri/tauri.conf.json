{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Clearity",
  "version": "0.1.0",
  "identifier": "io.clearity.desktop",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --filter @clearity/web dev"
  },
  "app": {
    "windows": [
      {
        "title": "Clearity",
        "url": "https://clearity-taupe.vercel.app",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "opener": {
      "open": true
    }
  }
}
